{
  "version": 1,
  "releaseUnits": [
    {
      "name": "terminal-ui",
      "type": "container-image",
      "path": ".",
      "artifact": "ghcr.io/yhf/roguelike-dungeon-crawler-terminal",
      "releaseStrategy": "component-publish",
      "requiredGates": ["release-guardrails", "frontend", "docker-build-terminal"],
      "promotionEnvironments": ["staging", "production"]
    },
    {
      "name": "agentic-brain",
      "type": "container-image",
      "path": "agentic-brain",
      "artifact": "ghcr.io/yhf/roguelike-dungeon-crawler-brain",
      "releaseStrategy": "component-publish",
      "requiredGates": ["release-guardrails", "backend", "docker-build-brain"],
      "promotionEnvironments": ["staging", "production"]
    }
  ]
}
